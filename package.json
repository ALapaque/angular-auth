{
  "name": "generic-angular-auth",
  "version": "0.1.0",
  "description": "Pluggable Angular authentication layer with adapters for OIDC, MSAL, Firebase, JWT and Mock providers.",
  "license": "MIT",
  "private": false,
  "sideEffects": false,
  "keywords": [
    "angular",
    "auth",
    "authentication",
    "oidc",
    "msal",
    "firebase",
    "jwt",
    "keycloak",
    "auth0"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "rxjs": ">=7.0.0",
    "angular-auth-oidc-client": ">=17.0.0",
    "@azure/msal-angular": ">=5.0.0",
    "@azure/msal-browser": ">=5.0.0",
    "firebase": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "angular-auth-oidc-client": { "optional": true },
    "@azure/msal-angular": { "optional": true },
    "@azure/msal-browser": { "optional": true },
    "firebase": { "optional": true }
  },
  "devDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@azure/msal-angular": "^5.0.0",
    "@azure/msal-browser": "^5.0.0",
    "angular-auth-oidc-client": "^21.0.0",
    "firebase": "^11.0.0",
    "ng-packagr": "^21.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.0",
    "typescript": "~5.9.0",
    "zone.js": "^0.15.0"
  }
}
